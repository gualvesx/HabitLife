# ── MIME Types ──────────────────────────────────────────────────────────
AddType model/gltf-binary          .glb
AddType model/gltf+json            .gltf
AddType application/javascript     .js .mjs
AddType application/manifest+json  .json
AddType text/css                   .css
AddType image/svg+xml              .svg
AddType image/png                  .png
AddType application/vnd.android.package-archive .apk

# ── CORS for Three.js assets & SW ───────────────────────────────────────
<FilesMatch "\.(glb|gltf|js|css|svg|png|json|apk)$">
  Header set Access-Control-Allow-Origin "*"
  Header set Access-Control-Allow-Methods "GET, OPTIONS"
</FilesMatch>

# Service Worker: no-cache so updates deploy immediately
<FilesMatch "sw\.js$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Service-Worker-Allowed "/"
</FilesMatch>


# ── APK download — must be served as binary, never as HTML ───────────────
<FilesMatch "\.apk$">
  ForceType application/vnd.android.package-archive
  Header set Content-Disposition "attachment"
  Header set X-Content-Type-Options "nosniff"
</FilesMatch>
# ── Compression ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/manifest+json
</IfModule>

# ── Cache headers ────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType model/gltf-binary        "access plus 1 month"
  ExpiresByType image/svg+xml            "access plus 1 month"
  ExpiresByType application/vnd.android.package-archive "access plus 1 week"
  ExpiresByType image/png                "access plus 1 month"
  ExpiresByType application/javascript   "access plus 1 week"
  ExpiresByType text/css                 "access plus 1 week"
</IfModule>

# ── React Router SPA ────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^sw\.js$ - [L]
  RewriteRule ^manifest\.json$ - [L]
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^downloads/.*\.apk$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
